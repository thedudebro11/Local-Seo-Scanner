{
  "appId": "com.localseoscanner.app",
  "productName": "Local SEO Scanner",
  "copyright": "Copyright © 2024",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    "out/**",
    "!out/**/*.map"
  ],
  "extraResources": [
    {
      "from": "reports",
      "to": "reports",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "icon": "build/icon.ico"
  },
  "mac": {
    "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
    "icon": "build/icon.icns"
  },
  "linux": {
    "target": [{ "target": "AppImage", "arch": ["x64"] }],
    "icon": "build/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
